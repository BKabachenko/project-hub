// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  emailVerified DateTime?  @map("email_verified")
  name          String?
  createdAt     DateTime   @default(now())
  status        UserStatus @default(ACTIVE)
  updatedAt     DateTime   @updatedAt
  image         String?

  authoredProjects   Project[]
  projectMemberships ProjectMember[]
  userReview         UserReview[]    @relation(name: "ReviewAuthor")
  receivedReviews    UserReview[]    @relation(name: "ReviewTarget")
  projectReviews     ProjectReview[]
  accounts           Account[]
  sessions           Session[]
}

model Project {
  id                   String          @id @default(cuid())
  authorId             String
  title                String
  description          String
  category             ProjectCategory
  type                 ProjectType[]
  status               ProjectStatus   @default(ACTIVE)
  requiredParticipants Int             @default(1)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  authorUser       User                 @relation(fields: [authorId], references: [id])
  projectMembers   ProjectMember[]
  projectReviews   ProjectReview[]
  membersReviews   UserReview[]
  projectPositions ProjectRequirement[]
}

model ProjectMember {
  userId    String
  projectId String
  status    ProjectMemberStatus
  role      MemberRole
  joinedAt  DateTime            @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@id([userId, projectId, role])
}

model ProjectRequirement {
  projectId     String
  role          MemberRole
  requiredCount Int        @default(1)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@id([projectId, role])
}

model ProjectReview {
  authorId  String
  projectId String
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating    Int

  user    User    @relation(fields: [authorId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@id([authorId, projectId])
}

model UserReview {
  authorId  String
  targetId  String
  projectId String
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating    Int

  reviewAuthor User    @relation(name: "ReviewAuthor", fields: [authorId], references: [id])
  targetUser   User    @relation(name: "ReviewTarget", fields: [targetId], references: [id])
  project      Project @relation(fields: [projectId], references: [id])

  @@id([authorId, targetId, projectId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserStatus {
  ACTIVE
  DELETED
  BANNED
}

enum MemberRole {
  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULLSTACK_DEVELOPER
  PROJECT_MANAGER
  UI_UX_DESIGNER
  QA_ENGINEER
  DEVOPS_ENGINEER
  BUSINESS_ANALYST
  DATA_SCIENTIST
  MARKETING_SPECIALIST
  OWNER
}

enum ProjectStatus {
  ACTIVE
  FINISHED
  CLOSED
}

enum ProjectMemberStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ProjectCategory {
  E_COMMERCE
  EDUCATION
  HEALTHCARE
  FINANCE
  SOCIAL_NETWORK
  PRODUCTIVITY
  ENTERTAINMENT
  REAL_ESTATE
  TRAVEL
  FOOD_DELIVERY
  LOGISTICS
  SAAS
  ARTIFICIAL_INTELLIGENCE
  BLOCKCHAIN
  IOT
  GAMING
  FITNESS
  MUSIC
  VIDEO
  NEWS
  JOB_BOARD
  DATING
  CROWDFUNDING
  CRM
  ERP
  MARKETPLACE
  STREAMING
  ANALYTICS
  CYBERSECURITY
  AR_VR
}

enum ProjectType {
  PET_PROJECT
  COMMERCIAL
  OPEN_SOURCE
  CHARITY
}
