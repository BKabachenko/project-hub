// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String?    @unique
  emailVerified DateTime?  @map("email_verified")
  name          String?
  createdAt     DateTime   @default(now())
  status        UserStatus @default(ACTIVE)
  updatedAt     DateTime   @updatedAt
  image         String?

  authoredProjects   Project[]
  projectMemberships ProjectMember[]
  userReview         UserReview[]    @relation(name: "ReviewAuthor")
  receivedReviews    UserReview[]    @relation(name: "ReviewTarget")
  projectReviews     ProjectReview[]
  accounts           Account[]
  sessions           Session[]
  applications       Application[]
}

model Project {
  id          String          @id @default(cuid())
  authorId    String
  title       String
  description String
  category    ProjectCategory
  type        ProjectType[]
  status      ProjectStatus   @default(ACTIVE)
  gitUrl      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  authorUser       User                 @relation(fields: [authorId], references: [id])
  projectMembers   ProjectMember[]
  projectReviews   ProjectReview[]
  membersReviews   UserReview[]
  requirements     ProjectRequirement[]
  milestones       Milestone[]
}

model ProjectMember {
  id            String              @id @default(cuid())
  userId        String
  projectId     String
  requirementId String
  status        ProjectMemberStatus @default(ACTIVE)
  joinedAt      DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user        User               @relation(fields: [userId], references: [id])
  project     Project            @relation(fields: [projectId], references: [id])
  requirement ProjectRequirement @relation(fields: [requirementId], references: [id])

  @@unique([userId, requirementId])
}

model ProjectRequirement {
  id                 String     @id @default(cuid())
  projectId          String
  role               MemberRole
  requiredCount      Int        @default(1)
  openPositionsCount Int        @default(0)
  techStack          String[]   @default([])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  project      Project         @relation(fields: [projectId], references: [id])
  applications Application[]
  members      ProjectMember[]
}

model ProjectReview {
  authorId  String
  projectId String
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating    Int

  user    User    @relation(fields: [authorId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@id([authorId, projectId])
}

model UserReview {
  authorId  String
  targetId  String
  projectId String
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rating    Int

  reviewAuthor User    @relation(name: "ReviewAuthor", fields: [authorId], references: [id])
  targetUser   User    @relation(name: "ReviewTarget", fields: [targetId], references: [id])
  project      Project @relation(fields: [projectId], references: [id])

  @@id([authorId, targetId, projectId])
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  requirementId String
  status        ApplicationStatus @default(PENDING)
  coverLetter   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User               @relation(fields: [userId], references: [id])
  requirement ProjectRequirement @relation(fields: [requirementId], references: [id])

  @@unique([userId, requirementId])
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      MilestoneStatus @default(PLANNED)
  order       Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, order])
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserStatus {
  ACTIVE
  DELETED
  BANNED
}

enum MemberRole {
  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  FULLSTACK_DEVELOPER
  PROJECT_MANAGER
  UI_UX_DESIGNER
  QA_ENGINEER
  DEVOPS_ENGINEER
  BUSINESS_ANALYST
  DATA_SCIENTIST
  MARKETING_SPECIALIST
  OWNER
}

enum ProjectStatus {
  ACTIVE
  FINISHED
  CLOSED
}

enum ProjectMemberStatus {
  ACTIVE
  LEFT
  REMOVED
}

enum ProjectCategory {
  E_COMMERCE
  EDUCATION
  HEALTHCARE
  FINANCE
  SOCIAL_NETWORK
  PRODUCTIVITY
  ENTERTAINMENT
  REAL_ESTATE
  TRAVEL
  FOOD_DELIVERY
  LOGISTICS
  SAAS
  ARTIFICIAL_INTELLIGENCE
  BLOCKCHAIN
  IOT
  GAMING
  FITNESS
  MUSIC
  VIDEO
  NEWS
  JOB_BOARD
  DATING
  CROWDFUNDING
  CRM
  ERP
  MARKETPLACE
  STREAMING
  ANALYTICS
  CYBERSECURITY
  AR_VR
}

enum ProjectType {
  PET_PROJECT
  COMMERCIAL
  OPEN_SOURCE
  CHARITY
}

enum ApplicationStatus {
  PENDING
  APPROVED
  DECLINED
  WITHDRAWN
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
